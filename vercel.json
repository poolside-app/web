{
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "bishopestates.poolsideapp.com" }
      ],
      "destination": "/club/index.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "(?<slug>[a-z0-9][a-z0-9-]*)\\.poolsideapp\\.com"
        }
      ],
      "missing": [
        { "type": "host", "value": "www\\.poolsideapp\\.com" }
      ],
      "destination": "/club/index.html"
    }
  ]
}
